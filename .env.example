# Private pilot access
RELEASE_ROOM_ACCESS_KEY=replace-with-a-long-private-key
RELEASE_ROOM_SESSION_SECRET=replace-with-a-long-random-secret
RELEASE_ROOM_WEBHOOK_SECRET=replace-with-a-long-editor-and-generic-webhook-secret
RELEASE_ROOM_PUBLIC_URL=http://localhost:3000
RELEASE_ROOM_LIVE_INTERVAL_MS=15000
RELEASE_ROOM_SECURE_COOKIES=true

# Persistence (local SQLite by default; use durable libSQL/Turso when hosted)
DATABASE_URL=file:release-room.db
DATABASE_AUTH_TOKEN=

# GitHub read/backfill and optional outbound checks
# Repository, commit, and PR context come from each Release Room candidate.
# Use a least-privilege token; Checks write is required only when outbound checks are enabled.
GITHUB_TOKEN=
GITHUB_CHECKS_ENABLED=false

# GitHub signed webhook ingestion
GITHUB_WEBHOOK_SECRET=

# Linear read/backfill and webhook
# The issue identifier comes from each candidate's Linear URL.
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=

# Vercel read/backfill and webhook
# A deployment is accepted only when its commit matches the release candidate.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_WEBHOOK_SECRET=
