# Private access
RELEASE_ROOM_ACCESS_KEY=replace-with-a-long-private-key
RELEASE_ROOM_SESSION_SECRET=replace-with-a-long-random-secret
RELEASE_ROOM_WEBHOOK_SECRET=replace-with-a-long-editor-and-generic-webhook-secret
RELEASE_ROOM_PUBLIC_URL=http://localhost:3000
RELEASE_ROOM_LIVE_INTERVAL_MS=15000
RELEASE_ROOM_SECURE_COOKIES=true

# Persistence (local SQLite by default)
DATABASE_URL=file:release-room.db
DATABASE_AUTH_TOKEN=

# GitHub read/backfill adapter
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repository
GITHUB_PR_NUMBER=

# GitHub App / webhook readiness
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CHECKS_ENABLED=false

# Linear read/backfill and webhook
LINEAR_API_KEY=
LINEAR_ISSUE_ID=
LINEAR_WEBHOOK_SECRET=

# Vercel read/backfill and webhook
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_WEBHOOK_SECRET=
